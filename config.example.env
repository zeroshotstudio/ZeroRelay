# ZeroRelay Configuration
# Copy to .env and customize. Permissions should be 600.

# -- Relay --
ZERORELAY_HOST=0.0.0.0
ZERORELAY_PORT=8765
ZERORELAY_ROLES=              # Comma-separated. Empty = any role
ZERORELAY_MAX_HISTORY=50
ZERORELAY_OPERATOR=operator      # Role name that can issue [RESET]

# -- Security --
RELAY_TOKEN=                  # Set to a UUID. All bridges must match. Generated by setup.py.

# -- Telegram --
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USER_ID=             # Sender verification (from @userinfobot)
TELEGRAM_ROLE=operator
TELEGRAM_USE_SUDO=true
TELEGRAM_SENDER_ICONS=claude=\U0001f9e0 Claude,gpt=\U0001f916 GPT,gemini=\U0001f48e Gemini,ollama=\U0001f999 Ollama,zee=\u26a1 Zee
TELEGRAM_TAG_PATTERNS=claude:@claude,@c;gpt:@gpt,@g;gemini:@gemini,@gem;zee:@z,@zee;ollama:@ollama,@local
TELEGRAM_AI_SERVICES=zerorelay-claude,zerorelay-gpt

# -- Discord --
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ROLE=operator

# -- Slack --
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# -- Claude Code CLI --
CLAUDE_MODEL=claude-sonnet-4-20250514   # or claude-opus-4-6 for max capability
CLAUDE_TAGS=@claude,@c
CLAUDE_ROLE=claude
CLAUDE_TIMEOUT=120
CLAUDE_ADD_DIR=               # e.g. / for full filesystem, or /home/user/project
CLAUDE_SESSION_IDLE_SEC=1800  # Auto-reset session after 30 min idle

# -- Anthropic API --
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TAGS=@claude,@c
ANTHROPIC_ROLE=claude

# -- OpenAI API --
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TAGS=@gpt,@g
OPENAI_ROLE=gpt
# OPENAI_BASE_URL=  # For Together, Groq, etc.

# -- Gemini --
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TAGS=@gemini,@gem
GEMINI_ROLE=gemini

# -- Ollama --
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TAGS=@ollama,@local
OLLAMA_ROLE=ollama

# -- OpenClaw --
OPENCLAW_CONTAINER=openclaw-openclaw-gateway-1
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION=agent:main:zerorelay
OPENCLAW_GATEWAY=ws://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_TAGS=@z,@zee
OPENCLAW_ROLE=zee
OPENCLAW_TIMEOUT=130
OPENCLAW_MODE=cli              # cli (docker exec) or websocket (direct gateway)
OPENCLAW_OUTBOX=               # Path to outbox file for proactive messages (e.g. /opt/zerorelay/zee-outbox)
SESSION_IDLE_RESET_SEC=1800    # Auto-reset OpenClaw session after 30 min idle

# -- Setup Script --
# Used by setup.py --from-env (unattended mode)
# ZERORELAY_BACKENDS=anthropic_api,ollama   # Comma-separated backend keys
# ZERORELAY_CHATS=telegram,discord          # Comma-separated chat keys
