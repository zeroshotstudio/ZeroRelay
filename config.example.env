# ZeroRelay Configuration
# Copy to .env and customize. Permissions should be 600.
#
# IMPORTANT: Docker Compose does NOT support inline comments.
# Put all comments on their own line above the variable.

# -- Relay --
ZERORELAY_HOST=0.0.0.0
ZERORELAY_PORT=8765
# Comma-separated allowed roles. Empty = accept any role.
ZERORELAY_ROLES=
ZERORELAY_MAX_HISTORY=50
# Role name that can issue [RESET]
ZERORELAY_OPERATOR=operator

# -- Security --
# Set to a UUID. All bridges must match. Generated by setup.py.
RELAY_TOKEN=

# -- MCP Tool Broker --
# Seconds before pending tool calls expire
ZERORELAY_MCP_TIMEOUT=30
# Max MCP messages per window per role
ZERORELAY_MCP_RATE_MAX=60
# MCP rate limit window in seconds
ZERORELAY_MCP_RATE_WINDOW=60

# -- Telegram --
TELEGRAM_BOT_TOKEN=
# Numeric chat ID from @userinfobot (must be a number, not empty)
TELEGRAM_CHAT_ID=0
# Sender verification — numeric user ID from @userinfobot
TELEGRAM_USER_ID=0
TELEGRAM_ROLE=operator
TELEGRAM_USE_SUDO=true
TELEGRAM_SENDER_ICONS=claude=🧠 Claude,gpt=🤖 GPT,gemini=💎 Gemini,ollama=🦙 Ollama,zee=⚡ Zee
TELEGRAM_TAG_PATTERNS=claude:@claude,@c;gpt:@gpt,@g;gemini:@gemini,@gem;zee:@z,@zee;ollama:@ollama,@local
TELEGRAM_AI_SERVICES=zerorelay-claude,zerorelay-gpt

# -- Discord --
DISCORD_BOT_TOKEN=
# Numeric channel ID (must be a number, not empty)
DISCORD_CHANNEL_ID=0
DISCORD_ROLE=operator

# -- Slack --
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# -- Claude Code CLI --
# or claude-opus-4-6 for max capability
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TAGS=@claude,@c
CLAUDE_ROLE=claude
CLAUDE_TIMEOUT=120
# e.g. / for full filesystem, or /home/user/project
CLAUDE_ADD_DIR=
# Auto-reset session after 30 min idle
CLAUDE_SESSION_IDLE_SEC=1800

# -- Anthropic API --
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TAGS=@claude,@c
ANTHROPIC_ROLE=claude

# -- OpenAI API --
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TAGS=@gpt,@g
OPENAI_ROLE=gpt
# For Together, Groq, etc. — uncomment and set:
# OPENAI_BASE_URL=

# -- Gemini --
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TAGS=@gemini,@gem
GEMINI_ROLE=gemini

# -- Ollama --
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TAGS=@ollama,@local
OLLAMA_ROLE=ollama
# To run multiple Ollama models, duplicate the bridge with different
# OLLAMA_MODEL, OLLAMA_TAGS, and OLLAMA_ROLE values in each instance.

# -- OpenClaw --
OPENCLAW_CONTAINER=openclaw-openclaw-gateway-1
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION=agent:main:zerorelay
OPENCLAW_GATEWAY=ws://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_TAGS=@z,@zee
OPENCLAW_ROLE=zee
OPENCLAW_TIMEOUT=130
# cli (docker exec) or websocket (direct gateway)
OPENCLAW_MODE=cli
# Path to outbox file for proactive messages (e.g. /opt/zerorelay/zee-outbox)
OPENCLAW_OUTBOX=
# Auto-reset OpenClaw session after 30 min idle
SESSION_IDLE_RESET_SEC=1800

# -- Setup Script --
# Used by setup.py --from-env (unattended mode)
# ZERORELAY_BACKENDS=anthropic_api,ollama
# ZERORELAY_CHATS=telegram,discord
